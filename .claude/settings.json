{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",
      "Bash(python -m researcher_mcp.storage.db:*)",
      "Bash(python -m researcher_mcp.server)",
      "Bash(python -m orchestrator.daily_run:*)",
      "Bash(python scripts/seed_demo.py:*)",
      "Bash(python -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run python -m researcher_mcp:*)",
      "Bash(uv run python -m orchestrator:*)",
      "Bash(uv run streamlit run:*)",
      "Bash(streamlit run:*)",
      "Bash(uv sync)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)"
    ],
    "ask": [
      "Bash(uv add:*)",
      "Bash(uv pip install:*)",
      "Bash(pip install:*)",
      "Bash(npm install:*)",
      "Bash(rm:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Read(./.env)",
      "Read(./**/*.pem)",
      "Read(./**/id_rsa)"
    ]
  }
}
