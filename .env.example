# =============================================================================
# Quantum Research Hub — environment configuration
# Copy to .env and adjust. NEVER commit real secrets.
# All variables are OPTIONAL; sane local-first defaults are used when unset.
# =============================================================================

# --- Paths (relative to repo root unless absolute) ---------------------------
QRH_DB_PATH=db/dev.sqlite3
QRH_DATA_DIR=data
QRH_EXPERIMENTS_DIR=experiments

# --- Budget ------------------------------------------------------------------
# Default budget profile for the daily run when --profile is not passed.
# One of: low | medium | high
QRH_BUDGET_PROFILE=low

# --- arXiv ingestion ---------------------------------------------------------
# Polite delay (seconds) between arXiv API calls. arXiv asks for >= 3s.
QRH_ARXIV_MIN_INTERVAL=3.0
# Default lookback window (days) for the daily paper scout.
QRH_LOOKBACK_DAYS=2
# Hard ceiling on results requested from arXiv in one query.
QRH_ARXIV_MAX_RESULTS=50

# --- Paper memory ------------------------------------------------------------
# One of: vector | bm25 | hybrid. "vector" is a dependency-free local hashed
# embedding index; "hybrid" blends vector + BM25.
QRH_MEMORY_BACKEND=vector

# --- Safe experiment runner --------------------------------------------------
# Wall-clock seconds before a smoke experiment is killed.
QRH_EXPERIMENT_TIMEOUT_SECONDS=60
# Set to "1" to grant approval for actions that normally require it
# (package install, GPU, long runs). Leave unset/0 for safe defaults.
QRH_APPROVAL_GRANTED=0

# --- Optional model pass (NOT required for the MVP) --------------------------
# When enabled and a key is present, paper cards, idea generation, and daily
# reports get a bounded Claude JSON pass. If unavailable, the system falls back
# to deterministic local behavior.
QRH_ENABLE_MODEL_PASS=0
# ANTHROPIC_API_KEY=
# QRH_ANTHROPIC_API_KEY=
QRH_CLAUDE_MODEL=claude-sonnet-4-5
QRH_CLAUDE_MAX_TOKENS=1800
QRH_CLAUDE_TIMEOUT_SECONDS=60
